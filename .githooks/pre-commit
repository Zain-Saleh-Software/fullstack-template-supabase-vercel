#!/usr/bin/env bash
#
# Pre-commit hook: blocks secrets, .env files, rule violations, lint errors.
#
# Install via: make setup-hooks
#

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Pre-commit checks running..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ─── 0. Absolute Immutability Check ─────────────────────────────────────────
# Block ANY modification to skills/, RULES.md, CLAUDE.md, and validation script
echo "→ Checking for immutable file modifications..."
IMMUTABLE_PATTERNS="^skills/|^RULES\.md$|^CLAUDE\.md$|^scripts/validate-rules\.sh$"
MODIFIED_IMMUTABLE=$(git diff --cached --name-only | grep -E "$IMMUTABLE_PATTERNS" || true)
if [ -n "$MODIFIED_IMMUTABLE" ]; then
    echo "✗ CRITICAL: Immutable files have been staged for commit:"
    echo "$MODIFIED_IMMUTABLE" | while read -r file; do
        echo "    ✗ $file"
    done
    echo ""
    echo "  These files are the project constitution and MUST NEVER be modified."
    echo "  REVERT these changes immediately:"
    echo "    git reset HEAD $MODIFIED_IMMUTABLE"
    echo "    git checkout -- $MODIFIED_IMMUTABLE"
    exit 1
fi

# ─── 1. Run rule validation ─────────────────────────────────────────────────
echo "→ Running rules validator..."
if [ -f "scripts/validate-rules.sh" ]; then
    bash scripts/validate-rules.sh
    if [ $? -ne 0 ]; then
        echo "✗ Rules validation failed. See above for details."
        exit 1
    fi
else
    echo "  ! validate-rules.sh not found (may need to install hooks)"
fi

# ─── 2. Block .env files ────────────────────────────────────────────────────
if git diff --cached --name-only | grep -q '\.env'; then
    echo "✗ ERROR: Committing .env files is blocked."
    exit 1
fi

# ─── 3. Block secrets (basic regex check on staged files) ───────────────────
if git diff --cached -S"AKIA" -S"-----BEGIN PRIVATE KEY-----" -S"SUPABASE_SERVICE_ROLE_KEY" --pickaxe-regex --name-only | grep -q .; then
    echo "✗ ERROR: Potential secrets detected in staged files."
    echo "  Please remove secrets before committing. (Use .env for secrets)"
    exit 1
fi

# ─── 4. Backend Lint & Format (ruff) ────────────────────────────────────────
echo "→ Running backend formatter check..."
cd backend
ruff check . --quiet
if [ $? -ne 0 ]; then
    echo "✗ Backend lint failed. Run 'make lint' to fix."
    exit 1
fi
ruff format --check . --quiet
if [ $? -ne 0 ]; then
    echo "✗ Backend formatting failed. Run 'make format' to fix."
    exit 1
fi
cd ..

# ─── 5. Frontend Lint ───────────────────────────────────────────────────────
echo "→ Running frontend linter..."
cd frontend
npm run lint --silent 2>&1 | tail -3
if [ $? -ne 0 ]; then
    echo "✗ Frontend lint failed. Run 'make lint' to fix."
    exit 1
fi
cd ..

echo ""
echo "  ✓ Pre-commit checks passed"
exit 0
