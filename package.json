{
  "name": "fullstack-template",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready fullstack template for CRM/HR applications — Next.js + Supabase + Drizzle ORM",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . && tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx src/lib/db/seed.ts",
    "supabase:start": "npx supabase start",
    "supabase:reset": "npx supabase db reset",
    "setup": "npx supabase start && npm run db:push && npx supabase db execute --file drizzle/0001_custom_rls_and_triggers.sql && npm run db:seed",
    "validate-rules": "node scripts/validate-rules.js",
    "smoke-test": "node scripts/smoke-test.js"
  },
  "dependencies": {
    "@fontsource/cairo": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^9.27.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.49.8",
    "@tanstack/react-query": "^5.100.9",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.2",
    "lucide-react": "^0.511.0",
    "next": "16.2.6",
    "next-intl": "^4.1.0",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.20"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.1",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.3",
    "supabase": "^2.23.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.1"
  }
}
