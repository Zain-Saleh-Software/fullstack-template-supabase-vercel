    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.5.0",
    "vite": "^5.4.6",
    "vitest": "^2.0.5"
