# =============================================================================
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ---- App ----
APP_NAME=fullstack-template
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ---- Backend (FastAPI) ----
BACKEND_PORT=8000  # Change this if your host port conflicts
BACKEND_HOST=0.0.0.0
BACKEND_WORKERS=4
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# ---- Database ----
# Choose: "supabase" or "postgres"
DB_TYPE=supabase

# For direct PostgreSQL (when DB_TYPE=postgres)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# For Supabase (when DB_TYPE=supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ---- JWT ----
JWT_SECRET=change-me-to-a-long-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Observability ----
OTEL_ENDPOINT=http://localhost:4318/v1/traces
LOG_LEVEL=INFO
ENABLE_METRICS=true
ENABLE_TRACING=true

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_URL=http://localhost:5173
VITE_DEFAULT_LOCALE=en
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- Deployment ----
# Vercel
VERCEL_PROJECT_ID=your-vercel-project-id
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_TOKEN=your-vercel-token

# Render
RENDER_API_KEY=your-render-api-key

# ---- Error Tracking ----
# SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx

# ---- Caching ----
# REDIS_URL=redis://localhost:6379/0

# Docker
DOCKER_REGISTRY=your-registry
DOCKER_IMAGE_TAG=latest
