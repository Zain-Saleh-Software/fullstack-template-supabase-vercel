# =============================================================================
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ---- App ----
APP_NAME=fullstack-template
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ---- Backend (FastAPI) ----
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
BACKEND_WORKERS=4
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# ---- Database ----
DB_TYPE=postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# ---- JWT ----
JWT_SECRET=change-me-to-a-long-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Observability ----
LOG_LEVEL=INFO
ENABLE_METRICS=true

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_URL=http://localhost:5173
VITE_DEFAULT_LOCALE=en

# ---- Error Tracking ----
# SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx

# ---- Caching ----
# REDIS_URL=redis://localhost:6379/0
