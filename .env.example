# =============================================================================
# Environment Configuration (DEVELOPMENT)
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to source control.
# =============================================================================

# ---- App ----
NEXT_PUBLIC_APP_NAME=fullstack-template
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Database (Drizzle ORM) ----
# LOCAL DEVELOPMENT (Supabase CLI local instance)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# PRODUCTION (Supabase Transaction Pooler — port 6543 REQUIRED for serverless)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ---- Auth ----
# Supabase Auth handles JWT internally — no custom secrets needed

# ---- Observability ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ---- Environment ----
NODE_ENV=development
